<ui:FluentWindow x:Class="WinTools.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:views="clr-namespace:WinTools.Views"
        Title="WinTools - Windows系统管理工具"
        Height="800" Width="1400"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" Text="WinTools" 
                       VerticalAlignment="Center" Margin="16,0,0,0" Foreground="White"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="─" Width="46" Height="32" Click="Minimize_Click" Background="Transparent" Foreground="White" BorderThickness="0"/>
                <Button x:Name="MaximizeBtn" Content="□" Width="46" Height="32" Click="Maximize_Click" Background="Transparent" Foreground="White" BorderThickness="0"/>
                <Button Content="✕" Width="46" Height="32" Click="Close_Click" Background="Transparent" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧导航 -->
            <Border Grid.Column="0">
                <Border.Background>
                    <SolidColorBrush Color="{DynamicResource SystemFillColorSolidBackgroundBase}"/>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Logo -->
                    <Border Grid.Row="0" Padding="20,16">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="6" Background="#0078D4">
                                <TextBlock Text="W" FontSize="20" FontWeight="Bold" Foreground="White" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="WinTools" FontSize="18" FontWeight="SemiBold" 
                                       Foreground="White" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- 导航列表 -->
                    <ListBox Grid.Row="1" x:Name="NavList" SelectionChanged="NavList_SelectionChanged" 
                             BorderThickness="0" Background="Transparent" Padding="8,0">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="Padding" Value="12,10"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBoxItem Content="仪表盘" Tag="Dashboard"/>
                        <ListBoxItem Content="进程管理" Tag="Process"/>
                        <ListBoxItem Content="服务管理" Tag="Service"/>
                        <ListBoxItem Content="性能监视" Tag="Performance"/>
                        <ListBoxItem Content="磁盘管理" Tag="Disk"/>
                        <ListBoxItem Content="网络管理" Tag="Network"/>
                        <ListBoxItem Content="应用管理" Tag="App"/>
                        <ListBoxItem Content="设备管理" Tag="Device"/>
                        <ListBoxItem Content="启动项" Tag="Startup"/>
                        <ListBoxItem Content="环境变量" Tag="Environment"/>
                        <ListBoxItem Content="用户管理" Tag="User"/>
                        <ListBoxItem Content="电源管理" Tag="Power"/>
                        <ListBoxItem Content="关于" Tag="About"/>
                    </ListBox>
                </Grid>
            </Border>

            <!-- 右侧内容 -->
            <Frame Grid.Column="1" x:Name="ContentFrame" Navigated="ContentFrame_Navigated"/>
        </Grid>
    </Grid>
</ui:FluentWindow>

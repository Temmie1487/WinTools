<ui:FluentWindow x:Class="WinTools.Helpers.MessageBoxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="提示"
        SizeToContent="WidthAndHeight"
        MaxWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        ShowInTaskbar="False">
    <StackPanel Margin="16">
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <ui:SymbolIcon x:Name="IconDisplay" Symbol="Info24" FontSize="20" Foreground="#0078D4" Margin="0,0,10,0"/>
            <TextBlock x:Name="MessageText" Text="" TextWrapping="Wrap" VerticalAlignment="Center" Foreground="White" MaxWidth="300"/>
        </StackPanel>
        
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button x:Name="OKButton" Content="确定" Appearance="Primary" Click="OKButton_Click" Margin="0,0,8,0" Width="70"/>
            <ui:Button x:Name="CancelButton" Content="取消" Click="CancelButton_Click" Margin="0,0,8,0" Width="70" Visibility="Collapsed"/>
            <ui:Button x:Name="YesButton" Content="是" Click="YesButton_Click" Margin="0,0,8,0" Width="70" Visibility="Collapsed"/>
            <ui:Button x:Name="NoButton" Content="否" Click="NoButton_Click" Width="70" Visibility="Collapsed"/>
        </StackPanel>
    </StackPanel>
</ui:FluentWindow>

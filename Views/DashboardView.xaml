<Page x:Class="WinTools.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:local="clr-namespace:WinTools.Views"
      Title="仪表盘">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部操作栏 -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="仪表盘" FontSize="28" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ui:Button x:Name="AddTileBtn" Content="+ 添加磁贴" Click="AddTile_Click" Margin="0,0,8,0"/>
                    <ui:Button x:Name="EditModeBtn" Content="✎ 编辑" Click="EditMode_Click"/>
                </StackPanel>
            </Grid>

            <!-- 系统信息卡片 -->
            <Grid Grid.Row="1" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ui:Card Grid.Column="0" Margin="0,0,8,0">
                    <StackPanel>
                        <ui:SymbolIcon Symbol="Desktop24" FontSize="32" Foreground="#0078D4"/>
                        <TextBlock Text="计算机名" Foreground="Gray" Margin="0,8,0,4"/>
                        <TextBlock x:Name="ComputerName" Text="DESKTOP-XXXX" FontWeight="SemiBold"/>
                    </StackPanel>
                </ui:Card>
                
                <ui:Card Grid.Column="1" Margin="8,0,8,0">
                    <StackPanel>
                        <ui:SymbolIcon Symbol="WindowNew24" FontSize="32" Foreground="#0078D4"/>
                        <TextBlock Text="操作系统" Foreground="Gray" Margin="0,8,0,4"/>
                        <TextBlock x:Name="OSVersion" Text="Windows 11" FontWeight="SemiBold"/>
                    </StackPanel>
                </ui:Card>
                
                <ui:Card Grid.Column="2" Margin="8,0,8,0">
                    <StackPanel>
                        <ui:SymbolIcon Symbol="Person24" FontSize="32" Foreground="#0078D4"/>
                        <TextBlock Text="当前用户" Foreground="Gray" Margin="0,8,0,4"/>
                        <TextBlock x:Name="UserName" Text="Administrator" FontWeight="SemiBold"/>
                    </StackPanel>
                </ui:Card>
                
                <ui:Card Grid.Column="3" Margin="8,0,0,0">
                    <StackPanel>
                        <ui:SymbolIcon Symbol="Timer24" FontSize="32" Foreground="#0078D4"/>
                        <TextBlock Text="运行时间" Foreground="Gray" Margin="0,8,0,4"/>
                        <TextBlock x:Name="Uptime" Text="0天 0小时" FontWeight="SemiBold"/>
                    </StackPanel>
                </ui:Card>
            </Grid>

            <!-- 性能监控 -->
            <Grid Grid.Row="2" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ui:Card Grid.Column="0" Margin="0,0,8,0">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="CPU 使用率" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock x:Name="CpuPercent" Text="0%" FontSize="24" FontWeight="Bold" 
                                       Foreground="#0078D4" HorizontalAlignment="Right"/>
                        </Grid>
                        <ProgressBar x:Name="CpuBar" Value="0" Maximum="100" Height="6" Margin="0,16,0,0"/>
                    </StackPanel>
                </ui:Card>

                <ui:Card Grid.Column="1" Margin="8,0,0,0">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="内存使用" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock x:Name="MemPercent" Text="0%" FontSize="24" FontWeight="Bold" 
                                       Foreground="#0078D4" HorizontalAlignment="Right"/>
                        </Grid>
                        <ProgressBar x:Name="MemBar" Value="0" Maximum="100" Height="6" Margin="0,16,0,0"/>
                        <TextBlock x:Name="MemInfo" Text="0 GB / 0 GB" Foreground="Gray" Margin="0,8,0,0"/>
                    </StackPanel>
                </ui:Card>
            </Grid>

            <!-- 自定义磁贴区域 -->
            <Grid Grid.Row="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <TextBlock Grid.Row="0" Text="快捷磁贴" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                
                <ItemsControl Grid.Row="1" x:Name="TilesControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="TileCard" Width="180" Height="100" Margin="0,0,8,8" 
                                    Background="{ui:ThemeResource ControlFillColorDefaultBrush}" CornerRadius="8"
                                    Cursor="Hand" Tag="{Binding}"
                                    MouseMove="Tile_MouseMove" MouseLeftButtonDown="Tile_MouseDown" MouseLeftButtonUp="Tile_MouseUp"
                                    AllowDrop="True" Drop="Tile_Drop" DragEnter="Tile_DragEnter" DragLeave="Tile_DragLeave">
                                <Grid>
                                    <!-- 删除按钮 -->
                                    <Border x:Name="DeleteBtn" Width="20" Height="20" 
                                            HorizontalAlignment="Right" VerticalAlignment="Top"
                                            Margin="0,-6,-6,0" CornerRadius="10"
                                            Background="{ui:ThemeResource ControlOnImageFillColorDefaultBrush}" 
                                            Cursor="Hand"
                                            MouseLeftButtonDown="DeleteBtn_MouseDown" Tag="{Binding}"
                                            Visibility="Collapsed">
                                        <TextBlock Text="✕" Foreground="{ui:ThemeResource TextFillColorPrimaryBrush}" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   FontSize="10" FontWeight="Bold"/>
                                    </Border>
                                    
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <ui:SymbolIcon Symbol="{Binding Icon, Converter={StaticResource IconConverter}}" FontSize="28" 
                                                       Foreground="{Binding IconColor}" 
                                                       HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Title}" HorizontalAlignment="Center" 
                                                   Margin="0,8,0,4" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Value}" HorizontalAlignment="Center" 
                                                   Foreground="Gray" FontSize="12"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>

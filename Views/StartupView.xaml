<Page x:Class="WinTools.Views.StartupView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="启动项">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <ui:TextBox x:Name="SearchBox" Width="300" PlaceholderText="搜索启动项..." TextChanged="SearchBox_TextChanged"/>
            <ui:Button x:Name="RefreshBtn" Content="刷新" Margin="12,0,0,0" Click="RefreshBtn_Click"/>
            <ui:Button x:Name="DisableBtn" Content="禁用" Margin="8,0,0,0" Click="DisableBtn_Click"/>
            <ui:Button x:Name="EnableBtn" Content="启用" Margin="8,0,0,0" Click="EnableBtn_Click"/>
            <ui:Button x:Name="OpenLocationBtn" Content="打开位置" Margin="8,0,0,0" Click="OpenLocationBtn_Click"/>
        </StackPanel>
        
        <DataGrid Grid.Row="1" x:Name="StartupGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserSortColumns="True"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="发布者" Binding="{Binding Publisher}" Width="150"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                <DataGridTextColumn Header="位置" Binding="{Binding Location}" Width="150"/>
                <DataGridTextColumn Header="命令" Binding="{Binding Command}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
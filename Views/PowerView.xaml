<Page x:Class="WinTools.Views.PowerView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="电源管理">
    <Grid Margin="24">
        <StackPanel>
            <TextBlock Text="电源计划" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,16"/>
            
            <ui:Card Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="当前电源计划" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- 抽屉式下拉菜单 - Mica效果 -->
                        <Grid Grid.Column="0">
                            <Border x:Name="PowerPlanButton" 
                                    Background="{ui:ThemeResource ControlFillColorDefaultBrush}" 
                                    CornerRadius="4" 
                                    Padding="12,8" Cursor="Hand" MouseLeftButtonUp="PowerPlanButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="PowerPlanButtonText" Text="选择电源计划" VerticalAlignment="Center"/>
                                    <TextBlock Text=" ▼" FontSize="10" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <Popup x:Name="PowerPlanPopup" PlacementTarget="{Binding ElementName=PowerPlanButton}" 
                                   Placement="Bottom" StaysOpen="False" AllowsTransparency="True" 
                                   PopupAnimation="Slide">
                                <Border Background="{ui:ThemeResource ControlFillColorDefaultBrush}" 
                                        BorderBrush="{ui:ThemeResource ControlStrokeColorDefaultBrush}" 
                                        BorderThickness="1" 
                                        CornerRadius="4" Margin="0,2,0,0">
                                    <ListBox x:Name="PowerPlanList" Background="Transparent" 
                                             BorderThickness="0" Width="334"
                                             SelectionChanged="PowerPlanList_SelectionChanged">
                                        <ListBoxItem Content="平衡 (Balanced)" Tag="381b4222-f694-41f0-9685-ff5bb260df2e" Padding="12,8"/>
                                        <ListBoxItem Content="高性能 (High Performance)" Tag="8c5e7fda-e8bf-4a96-9a85-a6e23a8c635c" Padding="12,8"/>
                                        <ListBoxItem Content="节能 (Power Saver)" Tag="a1841308-3541-4fab-bc81-f71556f20b4a" Padding="12,8"/>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#3D3D3D"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter Property="Background" Value="#0078D4"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>
                        
                        <ui:Button Grid.Column="1" Content="刷新" Margin="8,0,0,0" Click="RefreshPowerPlan_Click"/>
                    </Grid>
                    <TextBlock x:Name="CurrentPlanName" Text="" Foreground="Gray" Margin="0,8,0,0"/>
                </StackPanel>
            </ui:Card>
            
            <TextBlock Text="电源状态" FontSize="20" FontWeight="SemiBold" Margin="0,16,0,16"/>
            
            <ui:Card Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,12">
                        <TextBlock Text="电池状态" Foreground="Gray" FontSize="12"/>
                        <TextBlock x:Name="BatteryStatus" Text="检测中..." FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                        <TextBlock Text="电池电量" Foreground="Gray" FontSize="12"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="BatteryPercent" Text="检测中..." FontSize="16" FontWeight="SemiBold"/>
                            <ProgressBar x:Name="BatteryBar" Value="0" Maximum="100" Width="100" Height="8" Margin="12,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,12">
                        <TextBlock Text="充电状态" Foreground="Gray" FontSize="12"/>
                        <TextBlock x:Name="ChargingStatus" Text="检测中..." FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                        <TextBlock Text="电池预计剩余" Foreground="Gray" FontSize="12"/>
                        <TextBlock x:Name="BatteryTime" Text="检测中..." FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,12">
                        <TextBlock Text="电源使用情况" Foreground="Gray" FontSize="12"/>
                        <TextBlock x:Name="PowerUsage" Text="检测中..." FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,12">
                        <TextBlock Text="电池电压" Foreground="Gray" FontSize="12"/>
                        <TextBlock x:Name="BatteryVoltage" Text="检测中..." FontSize="16" FontWeight="SemiBold"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="3" Grid.Column="0">
                        <TextBlock Text="节能设置" Foreground="Gray" FontSize="12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <ui:Button x:Name="BalancedBtn" Content="平衡" Margin="0,0,8,0" Click="Balanced_Click"/>
                            <ui:Button x:Name="PowerSaverBtn" Content="节能" Margin="0,0,8,0" Click="PowerSaver_Click"/>
                            <ui:Button x:Name="HighPerfBtn" Content="高性能" Click="HighPerf_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ui:Card>
        </StackPanel>
    </Grid>
</Page>

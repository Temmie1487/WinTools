<Page x:Class="WinTools.Views.AboutView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="关于">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24" HorizontalAlignment="Center">
            <!-- Logo -->
            <Border Width="100" Height="100" CornerRadius="20" Background="#0078D4" HorizontalAlignment="Center">
                <TextBlock Text="W" FontSize="56" FontWeight="Bold" Foreground="White" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            
            <!-- 应用名称 -->
            <TextBlock Text="WinTools" FontSize="32" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,20,0,0"/>
            
            <!-- 版本 -->
            <TextBlock Text="版本 1.0.0" FontSize="14" Foreground="Gray" 
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
            
            <!-- 分隔线 -->
            <Border Height="1" Background="Gray" Opacity="0.3" Margin="0,24,0,24" Width="500"/>
            
            <!-- 开发者信息 -->
            <TextBlock Text="开发者" FontSize="14" Foreground="Gray" HorizontalAlignment="Center"/>
            <TextBlock Text="Temmie1487" FontSize="18" FontWeight="SemiBold" 
                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
            
            <!-- 链接区域 -->
            <TextBlock Text="相关链接" FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,24,0,0"/>
            
            <ui:Card Margin="0,12,0,0" Width="400">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="#242424" Margin="0,0,12,0">
                        <ui:SymbolIcon Symbol="Globe24" FontSize="18" Foreground="#0078D4"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="项目主页" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="GitHub 项目页面" FontSize="11" Foreground="Gray"/>
                    </StackPanel>
                    <ui:Button Grid.Column="2" Content="打开" Click="ProjectPage_Click" VerticalAlignment="Center"/>
                </Grid>
            </ui:Card>
            
            <ui:Card Margin="0,8,0,0" Width="400">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="#242424" Margin="0,0,12,0">
                        <ui:SymbolIcon Symbol="ArrowDownload24" FontSize="18" Foreground="#0078D4"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="检查更新" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="当前版本 1.0.0" FontSize="11" Foreground="Gray"/>
                    </StackPanel>
                    <ui:Button Grid.Column="2" Content="检查" Click="CheckUpdate_Click" VerticalAlignment="Center"/>
                </Grid>
            </ui:Card>
            
            <ui:Card Margin="0,8,0,0" Width="400">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="#242424" Margin="0,0,12,0">
                        <ui:SymbolIcon Symbol="Code24" FontSize="18" Foreground="#0078D4"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="GitHub 主页" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="开发者个人主页" FontSize="11" Foreground="Gray"/>
                    </StackPanel>
                    <ui:Button Grid.Column="2" Content="打开" Click="GitHub_Click" VerticalAlignment="Center"/>
                </Grid>
            </ui:Card>
            
            <ui:Card Margin="0,8,0,0" Width="400">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="8" Background="#242424" Margin="0,0,12,0">
                        <ui:SymbolIcon Symbol="Video24" FontSize="18" Foreground="#0078D4"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="B站主页" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="Bilibili 视频作者" FontSize="11" Foreground="Gray"/>
                    </StackPanel>
                    <ui:Button Grid.Column="2" Content="打开" Click="Bilibili_Click" VerticalAlignment="Center"/>
                </Grid>
            </ui:Card>
            
            <!-- 功能介绍 -->
            <TextBlock Text="功能介绍" FontSize="18" FontWeight="SemiBold" Margin="0,32,0,16"/>
            
            <ui:Card Margin="0,0,0,8" Width="500">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="#0078D4" Margin="0,0,12,0">
                        <ui:SymbolIcon Symbol="Home24" FontSize="20" Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="仪表盘" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="系统概览信息" Foreground="Gray" TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </ui:Card>
            
            <ui:Card Margin="0,0,0,8" Width="500">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="#0078D4" Margin="0,0,12,0">
                        <ui:SymbolIcon Symbol="SlideSettings24" FontSize="20" Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="服务管理" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="管理系统服务" Foreground="Gray" TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </ui:Card>
            
            <ui:Card Margin="0,0,0,8" Width="500">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="#0078D4" Margin="0,0,12,0">
                        <ui:SymbolIcon Symbol="Gauge24" FontSize="20" Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="性能监视" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="实时监控系统性能" Foreground="Gray" TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </ui:Card>
            
            <ui:Card Margin="0,0,0,8" Width="500">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="#0078D4" Margin="0,0,12,0">
                        <ui:SymbolIcon Symbol="Database24" FontSize="20" Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="磁盘管理" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="查看磁盘分区信息" Foreground="Gray" TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </ui:Card>
            
            <ui:Card Margin="0,0,0,8" Width="500">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="#0078D4" Margin="0,0,12,0">
                        <ui:SymbolIcon Symbol="Globe24" FontSize="20" Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="网络管理" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="管理网络适配器" Foreground="Gray" TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </ui:Card>
            
            <ui:Card Margin="0,0,0,8" Width="500">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="#0078D4" Margin="0,0,12,0">
                        <ui:SymbolIcon Symbol="Desktop24" FontSize="20" Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="设备管理" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="查看硬件设备信息" Foreground="Gray" TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </ui:Card>
            
            <ui:Card Margin="0,0,0,8" Width="500">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="#0078D4" Margin="0,0,12,0">
                        <ui:SymbolIcon Symbol="Rocket24" FontSize="20" Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="启动项管理" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="管理开机启动项" Foreground="Gray" TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </ui:Card>
            
            <ui:Card Margin="0,0,0,8" Width="500">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="#0078D4" Margin="0,0,12,0">
                        <ui:SymbolIcon Symbol="Code24" FontSize="20" Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="环境变量" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="管理系统环境变量" Foreground="Gray" TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </ui:Card>
            
            <ui:Card Margin="0,0,0,8" Width="500">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="#0078D4" Margin="0,0,12,0">
                        <ui:SymbolIcon Symbol="Person24" FontSize="20" Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="用户管理" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="管理用户账户" Foreground="Gray" TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </ui:Card>
            
            <ui:Card Margin="0,0,0,8" Width="500">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="8" Background="#0078D4" Margin="0,0,12,0">
                        <ui:SymbolIcon Symbol="Power24" FontSize="20" Foreground="White"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="电源管理" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="管理电源计划" Foreground="Gray" TextWrapping="Wrap" FontSize="12" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </ui:Card>
            
            <!-- 版权 -->
            <TextBlock Text="Copyright © 2026 Temmie1487. All rights reserved." 
                       FontSize="12" Foreground="Gray" 
                       HorizontalAlignment="Center" Margin="0,24,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Page>

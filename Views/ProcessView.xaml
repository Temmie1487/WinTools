<Page x:Class="WinTools.Views.ProcessView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="进程管理">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <ui:TextBox x:Name="SearchBox" Width="300" PlaceholderText="搜索进程..." TextChanged="SearchBox_TextChanged"/>
            <ui:Button x:Name="RefreshBtn" Content="刷新" Margin="12,0,0,0" Click="RefreshBtn_Click"/>
            <ui:Button x:Name="OpenLocationBtn" Content="打开文件位置" Margin="8,0,0,0" Click="OpenLocationBtn_Click"/>
            <ui:Button x:Name="KillBtn" Content="结束进程" Margin="8,0,0,0" Click="KillBtn_Click" Appearance="Danger"/>
        </StackPanel>
        
        <DataGrid Grid.Row="1" x:Name="ProcessGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserSortColumns="True"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="PID" Binding="{Binding ProcessId}" Width="70"/>
                <DataGridTextColumn Header="名称" Binding="{Binding ProcessName}" Width="200"/>
                <DataGridTextColumn Header="内存 (MB)" Binding="{Binding MemoryMB}" Width="100"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                <DataGridTextColumn Header="CPU (%)" Binding="{Binding CpuPercent}" Width="80"/>
                <DataGridTextColumn Header="路径" Binding="{Binding FilePath}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
<Page x:Class="WinTools.Views.EnvironmentView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="环境变量">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <ui:TextBox x:Name="SearchBox" Width="300" PlaceholderText="搜索环境变量..." TextChanged="SearchBox_TextChanged"/>
            <ui:Button x:Name="RefreshBtn" Content="刷新" Margin="12,0,0,0" Click="RefreshBtn_Click"/>
            <ui:Button x:Name="AddBtn" Content="新建" Margin="8,0,0,0" Click="AddBtn_Click"/>
            <ui:Button x:Name="EditBtn" Content="编辑" Margin="8,0,0,0" Click="EditBtn_Click"/>
            <ui:Button x:Name="DeleteBtn" Content="删除" Margin="8,0,0,0" Click="DeleteBtn_Click"/>
        </StackPanel>
        
        <!-- 用户变量 -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="用户变量" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <DataGrid Grid.Row="1" x:Name="UserEnvGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      CanUserSortColumns="True"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="变量名" Binding="{Binding Name}" Width="200"/>
                    <DataGridTextColumn Header="变量值" Binding="{Binding Value}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
        
        <!-- 系统变量 -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="系统变量" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <DataGrid Grid.Row="1" x:Name="SystemEnvGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      CanUserSortColumns="True"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="变量名" Binding="{Binding Name}" Width="200"/>
                    <DataGridTextColumn Header="变量值" Binding="{Binding Value}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Page>
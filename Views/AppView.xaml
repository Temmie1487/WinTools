<Page x:Class="WinTools.Views.AppView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="应用管理">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <ui:TextBox x:Name="SearchBox" Width="300" PlaceholderText="搜索应用..." TextChanged="SearchBox_TextChanged"/>
            <ui:Button x:Name="RefreshBtn" Content="刷新" Margin="12,0,0,0" Click="RefreshBtn_Click"/>
            <ui:Button x:Name="UninstallBtn" Content="卸载" Margin="8,0,0,0" Click="UninstallBtn_Click" Appearance="Danger"/>
            <ui:Button x:Name="OpenLocationBtn" Content="打开位置" Margin="8,0,0,0" Click="OpenLocationBtn_Click"/>
        </StackPanel>
        
        <DataGrid Grid.Row="1" x:Name="AppGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserSortColumns="True"
                  HeadersVisibility="Column"
                  MouseDoubleClick="AppGrid_MouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="250" SortMemberPath="Name"/>
                <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="100" SortMemberPath="Version"/>
                <DataGridTextColumn Header="发布者" Binding="{Binding Publisher}" Width="150" SortMemberPath="Publisher"/>
                <DataGridTextColumn Header="大小" Binding="{Binding Size}" Width="100" SortMemberPath="SizeBytes"/>
                <DataGridTextColumn Header="安装路径" Binding="{Binding InstallLocation}" Width="*" SortMemberPath="InstallLocation"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
<Page x:Class="WinTools.Views.PerformanceView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="性能监视">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- CPU 信息 -->
            <ui:Card Grid.Row="0" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="CPU 使用率" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="CpuPercent" Text="0%" FontSize="24" FontWeight="Bold" 
                                   Foreground="#0078D4" HorizontalAlignment="Right"/>
                    </Grid>
                    <ProgressBar x:Name="CpuBar" Value="0" Maximum="100" Height="8"/>
                    <TextBlock x:Name="CpuInfo" Text="--" Foreground="Gray" Margin="0,8,0,0"/>
                </StackPanel>
            </ui:Card>

            <!-- GPU 信息 -->
            <ui:Card Grid.Row="1" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="GPU 使用率" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="GpuPercent" Text="0%" FontSize="24" FontWeight="Bold" 
                                   Foreground="#FF5722" HorizontalAlignment="Right"/>
                    </Grid>
                    <ProgressBar x:Name="GpuBar" Value="0" Maximum="100" Height="8"/>
                    <TextBlock x:Name="GpuInfo" Text="--" Foreground="Gray" Margin="0,8,0,0"/>
                </StackPanel>
            </ui:Card>

            <!-- 内存信息 -->
            <ui:Card Grid.Row="2" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="内存使用" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="MemPercent" Text="0%" FontSize="24" FontWeight="Bold" 
                                   Foreground="#0078D4" HorizontalAlignment="Right"/>
                    </Grid>
                    <ProgressBar x:Name="MemBar" Value="0" Maximum="100" Height="8"/>
                    <TextBlock x:Name="MemInfo" Text="--" Foreground="Gray" Margin="0,8,0,0"/>
                </StackPanel>
            </ui:Card>

            <!-- 磁盘信息 -->
            <Grid Grid.Row="3" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ui:Card Grid.Column="0" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="磁盘读取" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock x:Name="DiskRead" Text="0 MB/s" FontSize="20" Foreground="#4CAF50"/>
                    </StackPanel>
                </ui:Card>

                <ui:Card Grid.Column="1" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="磁盘写入" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock x:Name="DiskWrite" Text="0 MB/s" FontSize="20" Foreground="#FF9800"/>
                    </StackPanel>
                </ui:Card>
            </Grid>

            <!-- 网络信息 -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <ui:Card Grid.Column="0" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="网络上传" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock x:Name="NetSend" Text="0 KB/s" FontSize="20" Foreground="#2196F3"/>
                    </StackPanel>
                </ui:Card>

                <ui:Card Grid.Column="1" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="网络下载" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock x:Name="NetReceive" Text="0 KB/s" FontSize="20" Foreground="#9C27B0"/>
                    </StackPanel>
                </ui:Card>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
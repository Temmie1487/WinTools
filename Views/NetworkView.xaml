<Page x:Class="WinTools.Views.NetworkView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="网络管理">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <ui:Button x:Name="RefreshBtn" Content="刷新" Click="RefreshBtn_Click" Margin="0,0,8,0"/>
            <ui:Button x:Name="EnableBtn" Content="启用适配器" Click="EnableBtn_Click" Margin="0,0,8,0"/>
            <ui:Button x:Name="DisableBtn" Content="禁用适配器" Click="DisableBtn_Click" Margin="0,0,8,0"/>
            <ui:Button x:Name="IpConfigBtn" Content="释放/更新IP" Click="IpConfigBtn_Click" Margin="0,0,8,0"/>
            <ui:Button x:Name="FlushDnsBtn" Content="刷新DNS" Click="FlushDnsBtn_Click"/>
        </StackPanel>
        
        <DataGrid Grid.Row="1" x:Name="NetworkGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserSortColumns="True"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="适配器名称" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="250"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                <DataGridTextColumn Header="MAC地址" Binding="{Binding MacAddress}" Width="150"/>
                <DataGridTextColumn Header="IP地址" Binding="{Binding IpAddress}" Width="120"/>
                <DataGridTextColumn Header="子网掩码" Binding="{Binding Subnet}" Width="120"/>
                <DataGridTextColumn Header="网关" Binding="{Binding Gateway}" Width="120"/>
                <DataGridTextColumn Header="DNS服务器" Binding="{Binding Dns}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
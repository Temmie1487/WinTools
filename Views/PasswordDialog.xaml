<ui:FluentWindow x:Class="WinTools.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="修改密码"
        Height="220" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">
    <Grid Margin="20,50,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="新密码" Foreground="White" Margin="0,0,0,8"/>
        <PasswordBox Grid.Row="1" x:Name="PasswordBox" Margin="0,0,0,16" Background="#2D2D2D" Foreground="White"/>
        
        <TextBlock Grid.Row="2" Text="确认密码" Foreground="White" Margin="0,0,0,8"/>
        <PasswordBox Grid.Row="3" x:Name="ConfirmPasswordBox" Margin="0,0,0,16" Background="#2D2D2D" Foreground="White"/>
        
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <ui:Button Content="取消" Click="Cancel_Click" Margin="0,0,8,0"/>
            <ui:Button Content="确定" Appearance="Primary" Click="OK_Click"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
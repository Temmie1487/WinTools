<ui:FluentWindow x:Class="WinTools.Views.UserDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="创建用户"
        Height="300" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">
    <Grid Margin="20,50,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Row="0" Text="用户名" Foreground="White" Margin="0,0,0,8"/>
        <ui:TextBox Grid.Row="1" x:Name="NameBox" Margin="0,0,0,16"/>
        
        <TextBlock Grid.Row="2" Text="全名（可选）" Foreground="White" Margin="0,0,0,8"/>
        <ui:TextBox Grid.Row="3" x:Name="FullNameBox" Margin="0,0,0,16"/>
        
        <TextBlock Grid.Row="4" Text="密码" Foreground="White" Margin="0,0,0,8" VerticalAlignment="Top"/>
        <PasswordBox Grid.Row="4" x:Name="PasswordBox" Margin="0,24,0,0" Background="#2D2D2D" Foreground="White"/>
        
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <ui:Button Content="取消" Click="Cancel_Click" Margin="0,0,8,0"/>
            <ui:Button Content="确定" Appearance="Primary" Click="OK_Click"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>